+From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
+From: LuYahan <yahan@iscas.ac.cn>
+Date: Wed, 25 Feb 2026 10:12:20 +0800
+Subject: [PATCH] tmp: 1/n fixes for builds with wasm in jitless mode
+
+Original change description fixing the build breakages:
+
+commit eea5d8b6e242892b186ac1ecd8d0ef555972baf2
+Author: LuYahan <yahan@iscas.ac.cn>
+Date:   Wed Feb 25 10:12:20 2026 +0800
+
+    [wasm-interpreter] Update data segment access for refactored storage API
+
+    The data segment storage was refactored to use WireBytesRef instead of
+    separate size and start arrays. This change updates the interpreter
+    to use the new data_segments() API
+
+    Bug: 483092905
+    Change-Id: I0b842fc1aa94bf46b92c94caabbf8e760d100903
+    Reviewed-on: https://chromium-review.googlesource.com/c/v8/v8/+/7605783
+    Auto-Submit: Yahan Lu (LuYahan) <yahan@iscas.ac.cn>
+    Commit-Queue: Paolo Severini <paolosev@microsoft.com>
+    Reviewed-by: Paolo Severini <paolosev@microsoft.com>
+    Cr-Commit-Position: refs/heads/main@{#105469}
+
+Commit(s) causing build breakages:
+
+commit f70b478fbe4a606358ebfd932bb6f97aa23334a3
+Author: Clemens Backes <clemensb@chromium.org>
+Date:   Mon Feb 23 16:29:39 2026 +0100
+
+    Merged: Reland "[wasm] Refactor storage of data segments in instance"
+
+    This is a reland of commit 35c1c729ffbe05a4faf329307b1aaeb0bad6f1f4.
+    PS2 implements `data.drop` via a C call which is allows to write to
+    trusted space.
+
+    Original change's description:
+    > [wasm] Refactor storage of data segments in instance
+    >
+    > Move from a `FixedAddressArray` plus `FixedUInt32Array` (stored in the
+    > sandbox) to a `TrustedPodArray<WireBytesRef>`.
+    > Storing absolute addresses in the sandbox is not a good idea anyway. The
+    > new design makes the instance smaller, keeps related data closer
+    > together and generally improves ergonomics when creating or using the
+    > `data_segments` array.
+    >
+    > Drive-by: Use a few more `base::Vector` to pass around views into the
+    > wire bytes.
+    >
+    > R=jkummerow@chromium.org
+    >
+    > Bug: 483092905
+    > Change-Id: I0a8d9b93b0d6c5f84eb6d09d9a6d42cc875da99b
+    > Reviewed-on: https://chromium-review.googlesource.com/c/v8/v8/+/7572409
+    > Reviewed-by: Jakob Kummerow <jkummerow@chromium.org>
+    > Commit-Queue: Clemens Backes <clemensb@chromium.org>
+    > Cr-Commit-Position: refs/heads/main@{#105270}
+
+    Bug: 483092905
+
+    (cherry picked from commit e9f61f1bbcd8807817a75779b64f0381751c9f5c)
+
+    Change-Id: Ib0ca2a29d123cf5763e9af3120074880643bd468
+    Reviewed-on: https://chromium-review.googlesource.com/c/v8/v8/+/7689010
+    Commit-Queue: Francis McCabe <fgm@chromium.org>
+    Commit-Queue: Deepti Gandluri <gdeepti@chromium.org>
+    Owners-Override: Deepti Gandluri <gdeepti@chromium.org>
+    Reviewed-by: Francis McCabe <fgm@chromium.org>
+    Cr-Commit-Position: refs/branch-heads/14.6@{#49}
+    Cr-Branched-From: e04c3a1a2543bdbee7beac8846c9cbe8f657636f-refs/heads/14.6.202@{#1}
+    Cr-Branched-From: 3b0b01e6594ec362369dc16f069012a81748c8ba-refs/heads/main@{#105132}
+---
+ .../interpreter/wasm-interpreter-runtime-inl.h     |  2 +-
+ src/wasm/interpreter/wasm-interpreter-runtime.cc   | 14 ++++++++------
+ 2 files changed, 9 insertions(+), 7 deletions(-)
+
+diff --git a/src/wasm/interpreter/wasm-interpreter-runtime-inl.h b/src/wasm/interpreter/wasm-interpreter-runtime-inl.h
+index 9b76456bd66..e08645d0ff4 100644
+--- a/src/wasm/interpreter/wasm-interpreter-runtime-inl.h
++++ b/src/wasm/interpreter/wasm-interpreter-runtime-inl.h
+@@ -92,7 +92,7 @@ inline size_t WasmInterpreterRuntime::GetMemorySize() const {
+ }
+ 
+ inline void WasmInterpreterRuntime::DataDrop(uint32_t index) {
+-  wasm_trusted_instance_data()->data_segment_sizes()->set(index, 0);
++  wasm_trusted_instance_data()->data_segments()->set(index, WireBytesRef{});
+ }
+ 
+ inline void WasmInterpreterRuntime::ElemDrop(uint32_t index) {
+diff --git a/src/wasm/interpreter/wasm-interpreter-runtime.cc b/src/wasm/interpreter/wasm-interpreter-runtime.cc
+index de27506e9a0..6c5ac235f55 100644
+--- a/src/wasm/interpreter/wasm-interpreter-runtime.cc
++++ b/src/wasm/interpreter/wasm-interpreter-runtime.cc
+@@ -535,18 +535,20 @@ bool WasmInterpreterRuntime::MemoryInit(const uint8_t*& current_code,
+   DirectHandle<WasmTrustedInstanceData> trusted_data =
+       wasm_trusted_instance_data();
+   Address dst_addr;
+-  uint64_t src_max =
+-      trusted_data->data_segment_sizes()->get(data_segment_index);
++  wasm::WireBytesRef segment_source =
++      trusted_data->data_segments()->get(data_segment_index);
+   if (!BoundsCheckMemRange(dst, &size, &dst_addr) ||
+-      !base::IsInBounds(src, size, src_max)) {
++      !base::IsInBounds(src, size,
++                        static_cast<uint64_t>(segment_source.length()))) {
+     SetTrap(MessageTemplate::kWasmTrapMemOutOfBounds, current_code);
+     return false;
+   }
+ 
+-  Address src_addr =
+-      trusted_data->data_segment_starts()->get(data_segment_index) + src;
++  base::Vector<const uint8_t> wire_bytes =
++      trusted_data->native_module()->wire_bytes();
++  const uint8_t* src_addr = wire_bytes.data() + segment_source.offset() + src;
+   std::memmove(reinterpret_cast<void*>(dst_addr),
+-               reinterpret_cast<void*>(src_addr), size);
++               reinterpret_cast<const void*>(src_addr), size);
+   return true;
+ }
+ 
