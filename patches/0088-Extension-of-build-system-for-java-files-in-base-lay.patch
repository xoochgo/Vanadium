From: quh4gko8 <88831734+quh4gko8@users.noreply.github.com>
Date: Tue, 9 Jan 2024 05:58:19 +0000
Subject: [PATCH] Extension of build system for java files in base layer

---
 base/BUILD.gn                                 | 19 +++++++++++++++++++
 base/base_java_ext_deps.gni                   |  6 ++++++
 base/base_java_ext_sources.gni                |  6 ++++++
 base/base_java_ext_srcjar_deps.gni            |  6 ++++++
 base/base_library_loader_java_ext_deps.gni    |  6 ++++++
 base/base_library_loader_java_ext_sources.gni |  6 ++++++
 ...se_library_loader_java_ext_srcjar_deps.gni |  6 ++++++
 .../base_shared_preferences_java_ext_deps.gni |  6 ++++++
 ...se_shared_preferences_java_ext_sources.gni |  6 ++++++
 9 files changed, 67 insertions(+)
 create mode 100644 base/base_java_ext_deps.gni
 create mode 100644 base/base_java_ext_sources.gni
 create mode 100644 base/base_java_ext_srcjar_deps.gni
 create mode 100644 base/base_library_loader_java_ext_deps.gni
 create mode 100644 base/base_library_loader_java_ext_sources.gni
 create mode 100644 base/base_library_loader_java_ext_srcjar_deps.gni
 create mode 100644 base/base_shared_preferences_java_ext_deps.gni
 create mode 100644 base/base_shared_preferences_java_ext_sources.gni

diff --git a/base/BUILD.gn b/base/BUILD.gn
index c9811ba7835ed..561a5587cb176 100644
--- a/base/BUILD.gn
+++ b/base/BUILD.gn
@@ -4883,6 +4883,13 @@ if (is_android) {
       ":wrapped_class_loader_java",
     ]
 
+    import("base_java_ext_sources.gni")
+    sources += base_java_ext_sources
+    import("base_java_ext_deps.gni")
+    deps += base_java_ext_deps
+    import("base_java_ext_srcjar_deps.gni")
+    srcjar_deps += base_java_ext_srcjar_deps
+
     if (!is_cronet_build) {
       proguard_configs += [
         "android/proguard/chromium_apk.flags",
@@ -5474,6 +5481,13 @@ if (is_android) {
       "//third_party/androidx:androidx_annotation_annotation_java",
       "//third_party/jni_zero:jni_zero_java",
     ]
+
+    import("base_library_loader_java_ext_sources.gni")
+    sources += base_library_loader_java_ext_sources
+    import("base_library_loader_java_ext_deps.gni")
+    deps += base_library_loader_java_ext_deps
+    import("base_library_loader_java_ext_srcjar_deps.gni")
+    srcjar_deps += base_library_loader_java_ext_srcjar_deps
   }
 
   generate_jni("base_shared_preferences_jni") {
@@ -5497,6 +5511,11 @@ if (is_android) {
       "android/java/src/org/chromium/base/shared_preferences/SharedPreferencesManager.java",
       "android/java/src/org/chromium/base/shared_preferences/StrictPreferenceKeyChecker.java",
     ]
+
+    import("base_shared_preferences_java_ext_sources.gni")
+    sources += base_shared_preferences_java_ext_sources
+    import("base_shared_preferences_java_ext_deps.gni")
+    deps += base_shared_preferences_java_ext_deps
   }
 
   android_library("flagged_apis_java") {
